[0.445, "o", "\r\n"]
[0.001, "o", "\r\n------------------------------------------------------------\r\n  DEMO KICH BAN LOI\r\n------------------------------------------------------------\r\n  [1] Demo 'Chi tieu kep' (Double Spending)\r\n  [2] Demo ty gia hoi doai khong hop le\r\n  [0] Quay lai\r\n  Lua chon: "]
[1.531, "o", "1"]
[0.413, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[36m\r\n============================================================\r\n  DEMO: CHI TIEU KEP (Double Spending)\r\n============================================================\r\n\u001b[0m\u001b[33m\r\n  ╔══════════════════════════════════════════════════╗\r\n  ║  KHONG CO MUTEX - Hai dau cuoi cung luc rut     ║\r\n  ╚══════════════════════════════════════════════════╝\r\n"]
[0.705, "o", "\u001b[0m  So du ban dau: \u001b[33m1,000.00 USD\u001b[0m\r\n"]
[0.502, "o", "  Hai thiet bi dau cuoi cung thu rut \u001b[33m1,000.00 USD\u001b[0m...\r\n"]
[0.505, "o", "\u001b[2m  (Output phia duoi co the bi chen nhau — day chinh la bieu hien race condition)\r\n\u001b[0m\r\n"]
[0.816, "o", "    [Terminal-1] Kiem tra so du:     [Terminal-2] Kiem tra so du: 1000.00 USD\r\n1000.00 USD\r\n"]
[0.055, "o", "    [Terminal-2] >>> RUT THANH CONG! So du con lai:     [Terminal-1] >>> RUT THANH CONG! So du con lai: 0.00 USD\r\n0.00 USD\r\n"]
[0.606, "o", "\r\n  \u001b[1m>>> KET QUA:\u001b[0m So du cuoi cung = 0.00 USD\r\n\u001b[2m\r\n  Nhan Enter de xem phien ban CO mutex...\r\n\u001b[0m"]
[3.617, "o", "\r\n\u001b[32m\r\n  ╔══════════════════════════════════════════════════╗\r\n  ║  CO MUTEX - He thong Apex khoa tai khoan         ║\r\n  ╚══════════════════════════════════════════════════╝\r\n"]
[0.709, "o", "\u001b[0m  Tao tai khoan tam: ACC-0001 | So du: 1,000.00 USD\r\n"]
[0.504, "o", "  Hai thiet bi dau cuoi cung thu rut 1,000.00 USD...\r\n\r\n"]
[0.815, "o", "    [Terminal-2] Dang thu rut 1,000.00 USD...\r\n    [Terminal-1] Dang thu rut 1,000.00 USD...\r\n"]
[0.000, "o", "\u001b[32m    [Terminal-1] >>> RUT THANH CONG!\u001b[0m\r\n"]
[0.003, "o", "\u001b[31m    [Terminal-2] XXX Bi tu choi: \u001b[0mVuot han muc thu chi: can 1,000.00 USD, so du hien tai 0.00 USD, han muc thu chi 0.00 USD\r\n"]
[0.605, "o", "\r\n  \u001b[1m>>> KET QUA:\u001b[0m So du cuoi cung = 0.00 USD | So lan rut thanh cong: 1/2\r\n\u001b[32m  [OK] Mutex bao ve thanh cong! Chi 1 giao dich duoc chap thuan.\u001b[0m\r\n"]
[0.000, "o", "\r\n  \u001b[1m\u001b[36m[KET LUAN]\u001b[0m Mutex dam bao chi mot giao dich duoc xu ly\r\n  tai mot thoi diem, ngan chan chi tieu kep.\r\n\u001b[2m\r\n  Nhan Enter de tiep tuc...\u001b[0m"]
[2.583, "o", "\r\n"]
