[0.844, "o", "============================================================\r\n\u001b[1m\u001b[36m     HE THONG NGAN HANG DA TIEN TE  APEX\r\n\u001b[0m============================================================\r\n\r\n\u001b[36m [1]\u001b[0m  Tao tai khoan moi\r\n\u001b[36m [2]\u001b[0m  Nap tien\r\n\u001b[36m [3]\u001b[0m  Rut tien\r\n\u001b[36m [4]\u001b[0m  Chuyen khoan\r\n\u001b[36m [5]\u001b[0m  Xem thong tin tai khoan\r\n\u001b[36m [6]\u001b[0m  Lich su giao dich (theo tai khoan)\r\n\u001b[36m [7]\u001b[0m  Nhat ky giao dich toan he thong\r\n\u001b[36m [8]\u001b[0m  Cap nhat ty gia hoi doai\r\n\u001b[36m [9]\u001b[0m  Xem ty gia hoi doai hien tai\r\n\u001b[36m[10]\u001b[0m  Danh sach tat ca tai khoan\r\n\u001b[36m[11]\u001b[0m  Tao du lieu mau\r\n\u001b[36m[12]\u001b[0m  Demo kich ban loi\r\n\u001b[36m [0]\u001b[0m  Thoat\r\n------------------------------------------------------------\r\n"]
[0.000, "o", "  Lua chon: "]
[0.455, "o", "1"]
